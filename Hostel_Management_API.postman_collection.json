    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4000",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "student_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "caretaker_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔓 Public Endpoints",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Get Public Rooms",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/rooms",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms"]
            }
          }
        }
      ]
    },
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Student Registration",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "  pm.environment.set(\"student_token\", response.token);",
                  "  console.log(\"Student token saved:\", response.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"roll_number\": \"CS2024001\",\n  \"year\": 2,\n  \"department\": \"Computer Science\",\n  \"address\": \"123 Main St\",\n  \"phone\": \"1234567890\",\n  \"parent_contact\": \"9876543210\",\n  \"gender\": \"Male\",\n  \"residence_type\": \"Hosteller\",\n  \"preferred_room_type\": \"AC\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login (Admin/Student)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token && response.user) {",
                  "  if (response.user.role === 'admin') {",
                  "    pm.environment.set(\"admin_token\", response.token);",
                  "    console.log(\"Admin token saved:\", response.token);",
                  "  } else if (response.user.role === 'student') {",
                  "    pm.environment.set(\"student_token\", response.token);",
                  "    console.log(\"Student token saved:\", response.token);",
                  "  }",
                  "  pm.environment.set(\"user_name\", response.user.name);",
                  "  pm.environment.set(\"user_role\", response.user.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Caretaker Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "  pm.environment.set(\"caretaker_token\", response.token);",
                  "  console.log(\"Caretaker token saved:\", response.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"caretaker@example.com\",\n  \"password\": \"care123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/caretaker/login",
              "host": ["{{base_url}}"],
              "path": ["api", "caretaker", "login"]
            }
          }
        }
      ]
